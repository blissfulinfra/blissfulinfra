# Development image — uses Spring Boot DevTools for fast in-JVM restarts.
# Source is volume-mounted from the host; Gradle re-compiles on change and
# DevTools triggers a restart in ~2-3 s (vs. ~30 s for a full image rebuild).
#
# Usage (generated by `blissful-infra dev`):
#   docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up app

FROM gradle:8.12-jdk21

WORKDIR /app

# Copy dependency descriptors first so Docker caches the dep-download layer.
COPY gradlew .
COPY gradle ./gradle
COPY build.gradle.kts settings.gradle.kts ./
RUN chmod +x gradlew && ./gradlew dependencies --no-daemon -q 2>/dev/null || true

# Source files are bind-mounted at runtime (see docker-compose.dev.yaml).
# We run two Gradle processes:
#   1. `classes -t` — watches .kt files and recompiles incrementally
#   2. `bootRun`    — starts the app; DevTools restarts the JVM when .class files change
COPY run-dev.sh .
RUN chmod +x run-dev.sh

EXPOSE 8080

CMD ["./run-dev.sh"]
